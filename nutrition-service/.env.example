# NutriFit Nutrition-Service — Required Environment Variables
# Copy this file to NutriFit-nutrition.env and fill in your values.
# The nutrition-service shares the same JWT_SECRET as the backend — tokens are cross-service.
#
# Usage:
#   source backend/NutriFit-backend.env   (the backend env file covers all required vars)
#   ./mvnw spring-boot:run                (from nutrition-service/ directory)

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be ≥32 characters. Must be IDENTICAL to the backend's JWT_SECRET.
JWT_SECRET=your-secret-here-minimum-32-characters

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
# Connects to the nutrifit_nutrition schema (separate from the backend's nutrifit schema).
# Created automatically by backend/scripts/init-multiple-dbs.sh on first Docker startup.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/nutrifit_nutrition
SPRING_DATASOURCE_USERNAME=nutrifit
SPRING_DATASOURCE_PASSWORD=nutrifit
