# NutriFit Backend — Required Environment Variables
# Copy this file to NutriFit-backend.env and fill in your values.
# NutriFit-backend.env is gitignored and never committed.
#
# Usage:
#   source backend/NutriFit-backend.env   (before running Maven locally)
#   docker compose up                      (root docker-compose.yml reads env_file automatically)

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be ≥32 characters. Must be identical in backend AND nutrition-service.
JWT_SECRET=your-secret-here-minimum-32-characters

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Never use wildcard (*).
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Local Docker DB (used with SPRING_PROFILES_ACTIVE=local) ──────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nutrifit
DB_USER=nutrifit
DB_PASSWORD=nutrifit

# ── AWS RDS DB (used with SPRING_PROFILES_ACTIVE=rds) ────────────────────────
DB_HOST_RDS=your-rds-endpoint.rds.amazonaws.com
DB_PORT_RDS=5432
DB_NAME_RDS=NutriFit_dev
DB_USER_RDS=your-rds-username
DB_PASSWORD_RDS=your-rds-password

# ── Spring Profile ────────────────────────────────────────────────────────────
# local  → uses Docker PostgreSQL (DB_HOST / DB_PORT / DB_NAME / DB_USER / DB_PASSWORD)
# rds    → uses AWS RDS (DB_HOST_RDS / DB_PORT_RDS / etc.)
SPRING_PROFILES_ACTIVE=local
